<UserControl x:Class="Sortify.Views.FilterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Sortify.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:FilterViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="280">
    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,10">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <TextBlock Text="Filters" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                    <Button DockPanel.Dock="Right" Content="Reset" Command="{Binding ResetCommand}"
                            Padding="8,4" Margin="0" />
                </DockPanel>

                <!-- Minimum play duration -->
                <TextBlock Text="MINIMUM PLAY DURATION (SECONDS)" Style="{StaticResource Caption}" />
                <TextBox Text="{Binding MinSeconds, UpdateSourceTrigger=PropertyChanged, Delay=400}" />
                <TextBlock Text="Listens shorter than this are ignored (default 5s)."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,3,0,0" />

                <!-- Date range -->
                <TextBlock Text="DATE RANGE" Style="{StaticResource SectionHeader}" />
                <TextBlock Text="From" Style="{StaticResource Caption}" />
                <DatePicker SelectedDate="{Binding StartDate}" />
                <TextBlock Text="To" Style="{StaticResource Caption}" />
                <DatePicker SelectedDate="{Binding EndDate}" />

                <!-- Search -->
                <TextBlock Text="SEARCH (TRACK OR ARTIST)" Style="{StaticResource SectionHeader}" />
                <TextBox Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged, Delay=400}" />

                <!-- Time of day -->
                <TextBlock Text="TIME OF DAY" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="Start hour: " />
                            <Run Text="{Binding StartHour}" FontWeight="Bold" />
                        </TextBlock>
                        <Slider Minimum="0" Maximum="23" Value="{Binding StartHour}" TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Style="{StaticResource Caption}">
                            <Run Text="End hour: " />
                            <Run Text="{Binding EndHour}" FontWeight="Bold" />
                        </TextBlock>
                        <Slider Minimum="0" Maximum="23" Value="{Binding EndHour}" TickFrequency="1" IsSnapToTickEnabled="True" />
                    </StackPanel>
                </Grid>
                <TextBlock Text="Tip: set start &gt; end to span midnight (e.g. 22 to 2)."
                           Foreground="{StaticResource MutedBrush}" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0" />

                <!-- Day of week -->
                <TextBlock Text="DAYS OF WEEK" Style="{StaticResource SectionHeader}" />
                <ItemsControl ItemsSource="{Binding Days}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Label}" IsChecked="{Binding IsSelected}" Width="56" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Excluded artists -->
                <TextBlock Text="EXCLUDE ARTISTS" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewExcludedArtist, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Content="Add" Margin="6,0,0,0" Padding="10,4"
                            Command="{Binding AddExcludedArtistCommand}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding ExcludedArtists}" Margin="0,6,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush2}" CornerRadius="4" Margin="0,0,0,4" Padding="8,4">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button DockPanel.Dock="Right" Content="x" Padding="6,0" Margin="0"
                                            Command="{Binding DataContext.RemoveExcludedArtistCommand,
                                                       RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Excluded tracks -->
                <TextBlock Text="EXCLUDE TRACKS" Style="{StaticResource SectionHeader}" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewExcludedTrack, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1" Content="Add" Margin="6,0,0,0" Padding="10,4"
                            Command="{Binding AddExcludedTrackCommand}" />
                </Grid>
                <ItemsControl ItemsSource="{Binding ExcludedTracks}" Margin="0,6,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource PanelBrush2}" CornerRadius="4" Margin="0,0,0,4" Padding="8,4">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button DockPanel.Dock="Right" Content="x" Padding="6,0" Margin="0"
                                            Command="{Binding DataContext.RemoveExcludedTrackCommand,
                                                       RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
